def _download_csv(url, dest):
    try:
        import urllib.request, ssl
        print(f"  Downloading from {url} ...")
        # bypass Mac SSL cert verification (common issue with Python from python.org)
        ctx = ssl.create_default_context()
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
        with urllib.request.urlopen(url, context=ctx) as r, open(dest, "wb") as f:
            f.write(r.read())
        return True
    except Exception as e:
        print(f"  Download failed: {e}")
        return False


def load_kaggle_data():
    """
    Priority:
    1. Kaggle CLI  (kaggle datasets download -d blastchar/telco-customer-churn)
    2. Local file already present
    3. Public GitHub mirror (IBM repo)
    4. Synthetic fallback
    """
    # Try Kaggle CLI
    try:
        import kaggle
        print("  Using Kaggle API …")
        kaggle.api.authenticate()
        kaggle.api.dataset_download_files(
            "blastchar/telco-customer-churn", path=".", unzip=True
        )
    except Exception:
        pass

    # Try known local / newly-downloaded paths
    for p in KNOWN_PATHS:
        if os.path.exists(p):
            print(f"  Found dataset at: {p}")
            return pd.read_csv(p), "kaggle"

    # Try public mirror
    dest = os.path.join(HERE, "Telco-Customer-Churn.csv")
    if _download_csv(MIRROR_URL, dest):
        if os.path.exists(dest):
            print(f"  Downloaded dataset to: {dest}")
            return pd.read_csv(dest), "kaggle"

    # Synthetic fallback
    print("  ⚠  Could not obtain Kaggle dataset — using synthetic data instead.")
    print("     To use real data, run:  pip install kaggle && kaggle datasets download")
    print("     -d blastchar/telco-customer-churn\n")
    return _generate_synthetic(2000), "synthetic"


def _generate_synthetic(n=2000):
    df = pd.DataFrame()
    df["customerID"]      = [f"CUST_{i:04d}" for i in range(n)]
    df["tenure"]          = np.random.randint(1, 72, n)
    df["MonthlyCharges"]  = np.round(np.random.uniform(20, 120, n), 2)
    df["TotalCharges"]    = np.round(df["tenure"] * df["MonthlyCharges"] * np.random.uniform(0.9, 1.1, n), 2)
    df["Contract"]        = np.random.choice(["Month-to-month", "One year", "Two year"], p=[0.55, 0.25, 0.20], size=n)
    df["InternetService"] = np.random.choice(["DSL", "Fiber optic", "No"], p=[0.35, 0.45, 0.20], size=n)
    df["TechSupport"]     = np.random.choice(["Yes", "No", "No internet service"], size=n)
    df["OnlineSecurity"]  = np.random.choice(["Yes", "No", "No internet service"], size=n)
    df["PaymentMethod"]   = np.random.choice(["Electronic check", "Mailed check", "Bank transfer", "Credit card"], size=n)
    df["SeniorCitizen"]   = np.random.choice([0, 1], p=[0.84, 0.16], size=n)
    df["Partner"]         = np.random.choice(["Yes", "No"], size=n)
    df["Dependents"]      = np.random.choice(["Yes", "No"], p=[0.30, 0.70], size=n)
    df["PaperlessBilling"]= np.random.choice(["Yes", "No"], size=n)
    logit = (
        -1.5
        - 0.03 * df["tenure"]
        + 0.01 * df["MonthlyCharges"]
        + 1.20 * (df["Contract"] == "Month-to-month").astype(int)
        + 0.80 * (df["InternetService"] == "Fiber optic").astype(int)
        - 0.50 * (df["TechSupport"] == "Yes").astype(int)
        - 0.50 * (df["OnlineSecurity"] == "Yes").astype(int)
    )
    prob = 1 / (1 + np.exp(-logit))
    df["Churn"] = np.where(np.random.rand(n) < prob, "Yes", "No")
    return df


