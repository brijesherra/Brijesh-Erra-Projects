    "SeniorCitizen", "contract_type",
]

def _get_optional(df, col, fallback_val):
    return df[col] if col in df.columns else pd.Series(fallback_val, index=df.index)

def build_features(df):
    X = pd.DataFrame()
    X["tenure_months"]   = df["tenure_months"]
    X["monthly_charges"] = df["monthly_charges"]
    X["num_services"]    = df["num_services"]
    X["senior"]          = df["SeniorCitizen"].astype(int)
    X["fiber"]           = (_get_optional(df, "InternetService", "No") == "Fiber optic").astype(int)
    X["no_security"]     = (_get_optional(df, "OnlineSecurity", "No") == "No").astype(int)
    X["no_techsupport"]  = (_get_optional(df, "TechSupport",    "No") == "No").astype(int)
    X["paperless"]       = (_get_optional(df, "PaperlessBilling","No") == "Yes").astype(int)
    X["echeck"]          = (_get_optional(df, "PaymentMethod",  "Other") == "Electronic check").astype(int)
    dummies = pd.get_dummies(df["contract_type"], prefix="contract", drop_first=False)
    X = pd.concat([X, dummies], axis=1)
    return X


def build_churn_model(df):
    X = build_features(df)
    y = df["churned"]
    feat_names = list(X.columns)

    scaler   = StandardScaler()
    X_scaled = scaler.fit_transform(X)

    X_tr, X_te, y_tr, y_te = train_test_split(
        X_scaled, y, test_size=0.20, random_state=42, stratify=y
    )

    model = RandomForestClassifier(
        n_estimators=300, max_depth=10, min_samples_leaf=5,
        class_weight="balanced", random_state=42, n_jobs=-1
    )
    model.fit(X_tr, y_tr)

    df["churn_probability"] = np.round(model.predict_proba(X_scaled)[:, 1], 4)

    y_pred  = model.predict(X_te)
    y_proba = model.predict_proba(X_te)[:, 1]

    print("\n" + "="*60)
    print("  CHURN MODEL PERFORMANCE (Test Set)")
    print("="*60)
    print(classification_report(y_te, y_pred, target_names=["Stay", "Churn"]))
    print(f"  ROC-AUC: {roc_auc_score(y_te, y_proba):.4f}")

    importances = pd.Series(model.feature_importances_, index=feat_names).sort_values(ascending=False)
    print("\n  Top 5 Features:")
    for f, v in importances.head(5).items():
        print(f"  {'█' * int(v*50)}  {f} ({v:.3f})")

    return model, scaler, feat_names, df, (X_te, y_te, y_pred, y_proba)


# ─────────────────────────────────────────────────────────────────────────────
# 5. SEGMENTATION
# ─────────────────────────────────────────────────────────────────────────────

def segment_customers(df):
    seg = df[["clv", "churn_probability"]].copy()
    seg["clv_n"]   = (seg["clv"]   - seg["clv"].mean())   / seg["clv"].std()
    seg["churn_n"] = (seg["churn_probability"] - seg["churn_probability"].mean()) / seg["churn_probability"].std()

    km = KMeans(n_clusters=4, random_state=42, n_init=10)
    df["segment_id"] = km.fit_predict(seg[["clv_n", "churn_n"]])

    summary = df.groupby("segment_id").agg(
        mean_clv=("clv", "mean"), mean_churn=("churn_probability", "mean"),
        count=("customer_id", "count")
    ).reset_index()
    summary["clv_rank"]   = summary["mean_clv"].rank()
    summary["churn_rank"] = summary["mean_churn"].rank()

    def label(row):
        hv = row["clv_rank"]   > 2
        hc = row["churn_rank"] > 2
        if hv and hc:  return "High-Value at Risk"
        if hv:         return "High-Value Stable"
        if hc:         return "Low-Value at Risk"
        return "Low-Value Stable"

    summary["label"] = summary.apply(label, axis=1)
    df["segment"] = df["segment_id"].map(dict(zip(summary["segment_id"], summary["label"])))
    return df, summary


# ─────────────────────────────────────────────────────────────────────────────
# 6. ROI ANALYSIS
# ─────────────────────────────────────────────────────────────────────────────

def business_roi_analysis(df, intervention_cost=50.0, save_rate=0.30):
    df["expected_savings"] = np.round(df["churn_probability"] * save_rate * df["clv"], 2)
    df["net_roi"]          = np.round(df["expected_savings"] - intervention_cost, 2)
    df["worth_saving"]     = df["net_roi"] > 0

    actionable = df[df["worth_saving"]]
    predicted  = df[df["churn_probability"] >= 0.5]
    spend      = len(actionable) * intervention_cost
    saved      = actionable["expected_savings"].sum()
    roi        = (saved - spend) / spend * 100 if spend else 0

    print("\n" + "="*60)
    print("  BUSINESS ROI ANALYSIS")
    print("="*60)
    print(f"  Intervention cost / customer   : ${intervention_cost:.2f}")
    print(f"  Assumed save rate              : {save_rate*100:.0f}%")
    print(f"  Total customers                : {len(df):,}")
    print(f"  Predicted churners (≥50%)      : {len(predicted):,}")
    print(f"  Worth saving (positive ROI)    : {len(actionable):,}")
    print(f"  Intervention spend             : ${spend:,.0f}")
    print(f"  Expected revenue saved         : ${saved:,.0f}")
    print(f"  Net campaign ROI               : {roi:.1f}%")
    return df


