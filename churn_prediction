def preprocess(raw):
    df = raw.copy()

    # TotalCharges sometimes has spaces
    df["TotalCharges"] = pd.to_numeric(df["TotalCharges"], errors="coerce")
    df["TotalCharges"].fillna(df["MonthlyCharges"], inplace=True)

    df["churned"] = (df["Churn"] == "Yes").astype(int)

    # Normalise contract labels
    df["contract_type"] = df["Contract"].str.strip().replace({
        "Month-to-month": "Month-to-Month",
        "One year":       "One Year",
        "Two year":       "Two Year",
    })

    # Derived features
    df["tenure_months"]    = df["tenure"].astype(int)
    df["monthly_charges"]  = df["MonthlyCharges"].astype(float)

    def col_eq(col, val):
        """Return int Series: 1 where df[col]==val, 0 if column is missing."""
        if col in df.columns:
            return (df[col] == val).astype(int)
        return pd.Series(0, index=df.index)

    df["num_services"] = (
        col_eq("PhoneService",     "Yes") +
        col_eq("MultipleLines",    "Yes") +
        col_eq("OnlineSecurity",   "Yes") +
        col_eq("OnlineBackup",     "Yes") +
        col_eq("DeviceProtection", "Yes") +
        col_eq("TechSupport",      "Yes") +
        col_eq("StreamingTV",      "Yes") +
        col_eq("StreamingMovies",  "Yes")
    )
    df["customer_id"] = df["customerID"] if "customerID" in df.columns else df.index.astype(str)

    return df


# ─────────────────────────────────────────────────────────────────────────────
# 3. CLV
# ─────────────────────────────────────────────────────────────────────────────

def calculate_clv(df, discount_rate=0.10, margin_rate=0.30):
    monthly_discount = discount_rate / 12
    monthly_margin   = df["monthly_charges"] * margin_rate

    contract_churn_rates = {
        "Month-to-Month": 0.035,
        "One Year":       0.010,
        "Two Year":       0.005,
    }
    monthly_churn_rate = df["contract_type"].map(contract_churn_rates).fillna(0.02)

    df["monthly_margin"] = monthly_margin
    df["clv"] = np.round(monthly_margin / (monthly_discount + monthly_churn_rate), 2)
    return df


